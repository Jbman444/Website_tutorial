---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;

const {
  title,
  description,
  pubDate,
  image,
  tags = [],
} = frontmatter;

const formattedDate = pubDate
  ? new Date(pubDate).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  : '';
---

<BaseLayout pageTitle={title}>
  <article class="post">
    <header class="post-header">
      <p class="post-description"><em>{description}</em></p>
      {formattedDate && <p class="post-date">{formattedDate}</p>}
    </header>

    {image?.url && (
      <img
        class="post-image"
        src={image.url}
        alt={image.alt ?? ''}
      />
    )}

    <div class="post-content">
      <slot />
    </div>

    {tags.length > 0 && (
      <div class="tags" aria-label="Post tags">
        {tags.map((tag: string) => (
          <a class="tag" href={`/tags/${tag}`}>
            {tag}
          </a>
        ))}
      </div>
    )}
  </article>
</BaseLayout>

<style>
  .post {
    display: grid;
    gap: 1rem;
  }

  .post-header {
    display: grid;
    gap: 0.35rem;
  }

  .post-description,
  .post-date {
    margin: 0;
  }

  .post-description {
    color: #475569;
  }

  .post-date {
    font-size: 0.95rem;
    color: #64748b;
  }

  .post-image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 1rem;
  }

  .post-content {
    display: grid;
    gap: 1rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.9rem;
    border: 1px solid #cbd5e1;
    border-radius: 999px;
    background: #f8fafc;
    color: #111827;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .tag:hover,
  .tag:focus {
    background: #e2e8f0;
  }

  :global(html.dark) .post-description {
    color: #dbeafe;
  }

  :global(html.dark) .post-date {
    color: #cbd5e1;
  }

  :global(html.dark) .tag {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.16);
    color: white;
  }

  :global(html.dark) .tag:hover,
  :global(html.dark) .tag:focus {
    background: rgba(255, 255, 255, 0.14);
  }
</style>