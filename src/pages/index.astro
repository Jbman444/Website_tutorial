---
import Menu from '../components/Menu.astro';
import Navigation from '../components/Navigation.astro';
import ThemeIcon from '../components/ThemeIcon.astro';

const pageTitle = "Jorge L. Vargas Lara M.S.";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
  </head>

  <body>
    <div class="page-shell">
      <header class="site-header">
        <nav class="site-nav">
          <div class="nav-left">
            <ThemeIcon />
            <Menu />
          </div>
          <Navigation />
        </nav>
      </header>

      <main class="home-page">
        <section class="hero">
          <div class="logo-box">Logo</div>

          <div class="hero-text">
            <p class="eyebrow">Water Resources • Modeling • CFD</p>
            <h1 class="floating-name">Jorge L. Vargas Lara</h1>
            <p class="intro">
              I am a Water Resources Engineer focused on computational modeling,
              groundwater systems, and pore-scale flow processes. My work combines
              physics-based simulation with data-driven analysis to better understand
              environmental systems.
            </p>
          </div>

          <div class="visual-3d">3D Visual</div>
        </section>

        <section class="featured-grid">
          <article class="card">
            <div class="visual">Biofilm</div>
            <h2>Biofilm Research</h2>
            <p class="card-text">
              Pore-scale simulations and image-based modeling to study biofilm growth
              and its impact on flow and transport.
            </p>
          </article>

          <article class="card">
            <div class="visual">Groundwater</div>
            <h2>Groundwater Modeling</h2>
            <p class="card-text">
              MODFLOW and regional hydrogeologic analysis to evaluate groundwater
              systems and water resource management.
            </p>
          </article>

          <article class="card">
            <div class="visual">Data</div>
            <h2>Data & Visualization</h2>
            <p class="card-text">
              Python-based workflows for processing, analyzing, and visualizing
              environmental and simulation data.
            </p>
          </article>
        </section>

        <div class="social-row">
          <a
            href="https://www.linkedin.com/in/jorgelvlara"
            target="_blank"
            rel="noopener noreferrer"
          >
            LinkedIn
          </a>
          <a
            href="https://github.com/Jbman444"
            target="_blank"
            rel="noopener noreferrer"
          >
            GitHub
          </a>
        </div>
      </main>
    </div>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100%;
    font-family: Arial, sans-serif;
    background: #f8fafc;
    color: #111827;
  }

  :global(body) {
    min-height: 100vh;
  }

  .page-shell {
    min-height: 100vh;
    padding: 0.75rem 1rem;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 0.5rem;
  }

  .site-header {
    padding: 0.15rem 0;
  }

  .site-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .home-page {
    min-height: 0;
    display: grid;
    grid-template-rows: auto auto auto;
    gap: 0.8rem;
  }

  .hero {
    display: grid;
    grid-template-columns: 90px 1.5fr 0.85fr;
    gap: 0.8rem;
    align-items: start;
  }

  .logo-box {
    width: 90px;
    height: 90px;
    border: 2px dashed #94a3b8;
    border-radius: 1rem;
    display: grid;
    place-items: center;
    background: white;
  }

  .hero-text {
    min-width: 0;
  }

  .eyebrow {
    margin: 0 0 0.25rem;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #475569;
  }

  .floating-name {
    margin: 0 0 0.35rem;
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 0.95;
  }

  .intro {
    margin: 0;
    max-width: 54ch;
    font-size: 0.95rem;
    line-height: 1.35;
    color: #334155;
  }

  .visual-3d {
    min-height: 110px;
    border-radius: 1rem;
    background: #cbd5e1;
    display: grid;
    place-items: center;
    font-weight: 600;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.8rem;
    align-items: stretch;
  }

  .card {
    border: 1px solid #cbd5e1;
    border-radius: 1rem;
    padding: 0.65rem;
    background: white;
    min-height: 165px;
    display: flex;
    flex-direction: column;
  }

  .visual {
    height: 56px;
    border-radius: 0.75rem;
    background: #e2e8f0;
    display: grid;
    place-items: center;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .card h2 {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    line-height: 1.1;
  }

  .card-text {
    margin: 0;
    font-size: 0.87rem;
    line-height: 1.25;
    color: #475569;
  }

  .social-row {
    display: flex;
    gap: 0.75rem;
    align-items: end;
    margin-top: auto;
  }

  .social-row a {
    display: inline-block;
    padding: 0.65rem 1rem;
    border-radius: 1rem;
    background: #312e81;
    color: white;
    text-decoration: none;
    font-weight: 500;
  }

  .social-row a:hover,
  .social-row a:focus {
    opacity: 0.9;
  }

  @media (max-width: 900px) {
    .page-shell {
      min-height: auto;
    }

    .site-nav {
      flex-direction: column;
      align-items: stretch;
    }

    .hero {
      grid-template-columns: 1fr;
    }

    .featured-grid {
      grid-template-columns: 1fr;
    }

    .social-row {
      flex-wrap: wrap;
    }
  }
</style>