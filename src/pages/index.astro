---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Jorge L. Vargas Lara M.S.";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
  </head>

  <body>
    <Header />

    <main class="home-page">
      <section class="hero">
        <div class="hero-text">
          <p class="eyebrow">Water Resources • Modeling • CFD</p>
          <h1 class="floating-name">Jorge L. Vargas Lara</h1>
          <p class="intro">
            I am a Water Resources Engineer focused on computational modeling,
            groundwater systems, and pore-scale flow processes. My work combines
            physics-based simulation with data-driven analysis to better understand
            environmental systems.
          </p>
        </div>

        <div class="visual-3d">3D Visual</div>
      </section>

      <section class="featured-grid">
        <article class="card">
          <div class="visual">Biofilm</div>
          <h2>Biofilm Research</h2>
          <p class="card-text">
            Pore-scale simulations and image-based modeling to study biofilm growth
            and its impact on flow and transport.
          </p>
        </article>

        <article class="card">
          <div class="visual">Groundwater</div>
          <h2>Groundwater Modeling</h2>
          <p class="card-text">
            MODFLOW and regional hydrogeologic analysis to evaluate groundwater
            systems and water resource management.
          </p>
        </article>

        <article class="card">
          <div class="visual">Data</div>
          <h2>Data & Visualization</h2>
          <p class="card-text">
            Python-based workflows for processing, analyzing, and visualizing
            environmental and simulation data.
          </p>
        </article>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100%;
    font-family: Arial, sans-serif;
    background: #f1f5f9;
    color: #111827;
  }

  :global(body) {
    min-height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr;
  }

  :global(html.dark),
  :global(html.dark body) {
    background: #0d0950;
    color: white;
  }

  .home-page {
    min-height: 0;
    padding: 0.85rem 1rem 5rem;
    display: grid;
    grid-template-rows: auto auto;
    gap: 0.8rem;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.8fr 0.7fr;
    gap: 0.8rem;
    align-items: start;
  }

  .hero-text {
    min-width: 0;
  }

  .eyebrow {
    margin: 0 0 0.25rem;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #475569;
  }

  :global(html.dark) .eyebrow {
    color: #cbd5e1;
  }

  .floating-name {
    margin: 0 0 0.35rem;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 0.95;
  }

  .intro {
    margin: 0;
    max-width: 65ch;
    font-size: 0.98rem;
    line-height: 1.4;
    color: #334155;
  }

  :global(html.dark) .intro {
    color: #e2e8f0;
  }

  .visual-3d {
    min-height: 100px;
    border-radius: 1rem;
    background: #cbd5e1;
    display: grid;
    place-items: center;
    font-weight: 600;
  }

  :global(html.dark) .visual-3d {
    background: rgba(255, 255, 255, 0.14);
    color: white;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.8rem;
    align-items: stretch;
  }

  .card {
    border: 1px solid #cbd5e1;
    border-radius: 1rem;
    padding: 0.7rem;
    background: white;
    min-height: 165px;
    display: flex;
    flex-direction: column;
  }

  :global(html.dark) .card {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.14);
  }

  .visual {
    height: 56px;
    border-radius: 0.75rem;
    background: #e2e8f0;
    display: grid;
    place-items: center;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  :global(html.dark) .visual {
    background: rgba(255, 255, 255, 0.12);
  }

  .card h2 {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    line-height: 1.1;
  }

  .card-text {
    margin: 0;
    font-size: 0.87rem;
    line-height: 1.25;
    color: #475569;
  }

  :global(html.dark) .card-text {
    color: #dbeafe;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .featured-grid {
      grid-template-columns: 1fr;
    }

    .home-page {
      padding-bottom: 5.5rem;
    }
  }
</style>