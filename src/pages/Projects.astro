---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const allPosts = Object.values(
  import.meta.glob('./posts/*.{md,mdx}', { eager: true })
);

const pageTitle = "Notable Projects";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
  </head>

  <body>
    <Header />

    <main class="projects-page">
      <section class="hero">
        <div class="hero-text">
          <p class="eyebrow">Projects</p>
          <h1 class="floating-name">{pageTitle}</h1>
          <p class="intro">
            A selection of modeling, simulation, visualization, and environmental
            analysis work from my portfolio.
          </p>
        </div>

        <div class="visual-3d">Project Archive</div>
      </section>

      <section class="featured-grid">
        {allPosts.map((post: any) => (
          <article class="card">
            <a class="card-link" href={post.url}>
              <div class="visual">
                {post.frontmatter.image?.url ? (
                  <img
                    src={post.frontmatter.image.url}
                    alt={post.frontmatter.image.alt ?? post.frontmatter.title}
                  />
                ) : (
                  <span>Project</span>
                )}
              </div>

              <h2>{post.frontmatter.title}</h2>

              {post.frontmatter.description && (
                <p class="card-text">{post.frontmatter.description}</p>
              )}
            </a>
          </article>
        ))}
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100%;
    font-family: Arial, sans-serif;
    background: #f1f5f9;
    color: #111827;
  }

  :global(body) {
    min-height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr;
  }

  :global(html.dark),
  :global(html.dark body) {
    background: #0d0950;
    color: white;
  }

  .projects-page {
    min-height: 0;
    padding: 0.75rem 1rem 5rem;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 0.7rem;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.5fr 0.85fr;
    gap: 0.7rem;
    align-items: start;
  }

  .hero-text {
    min-width: 0;
  }

  .eyebrow {
    margin: 0 0 0.2rem;
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #475569;
  }

  :global(html.dark) .eyebrow {
    color: #cbd5e1;
  }

  .floating-name {
    margin: 0 0 0.3rem;
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 0.95;
  }

  .intro {
    margin: 0;
    max-width: 58ch;
    font-size: 0.92rem;
    line-height: 1.3;
    color: #334155;
  }

  :global(html.dark) .intro {
    color: #e2e8f0;
  }

  .visual-3d {
    min-height: 100px;
    border-radius: 1rem;
    background: #cbd5e1;
    display: grid;
    place-items: center;
    font-weight: 600;
  }

  :global(html.dark) .visual-3d {
    background: rgba(255, 255, 255, 0.14);
    color: white;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.7rem;
    align-items: stretch;
    min-height: 0;
  }

  .card {
    border: 1px solid #cbd5e1;
    border-radius: 1rem;
    background: white;
    min-height: 185px;
    overflow: hidden;
  }

  :global(html.dark) .card {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.14);
  }

  .card-link {
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 0.65rem;
    text-decoration: none;
    color: inherit;
  }

  .visual {
    height: 88px;
    border-radius: 0.75rem;
    background: #e2e8f0;
    display: grid;
    place-items: center;
    overflow: hidden;
    font-weight: 600;
  }

  .visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  :global(html.dark) .visual {
    background: rgba(255, 255, 255, 0.12);
  }

  .card h2 {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.08;
  }

  .card-text {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.2;
    color: #475569;
  }

  :global(html.dark) .card-text {
    color: #dbeafe;
  }

  @media (max-width: 900px) {
    .projects-page {
      padding-bottom: 5.5rem;
    }

    .hero {
      grid-template-columns: 1fr;
    }

    .featured-grid {
      grid-template-columns: 1fr;
    }
  }
</style>